---
layout: layouts/base.njk
title: "Curriculum Vitae"
pagination:
  data: variants
  size: 1
  alias: variant
permalink: "{{ variant.permalink }}"
---

<div class="sheet-outer letter">
<div class="d-print-none text-center mb-2">
  <a href="{{ ('/cv-' + variant.key + '.pdf') | url }}" class="btn btn-sm btn-primary">Download PDF</a>
</div>
<div class="sheet">
<div class="d-flex flex-row">
<div class="d-flex flex-column justify-content-between ps-3 pe-4 pt-3 pb-3" style="height: 11in; width: 6.7in;">
<div id="intro" class="mb-3 ps-3 border-start border-4 border-dark">
<div class="d-flex flex-row justify-content-between">
<h1 class="mt-0 {{ 'mb-1' if variant.profile.title else 'mb-3' }} text-nowrap"{{ (' style="font-size: ' ~ variant.profile.nameSize ~ ';"' if variant.profile.nameSize else '') | safe }}>{{ profile.name }}</h1>
<span class="text-muted fw-light font-monospace" style="font-size: {{ variant.profile.titleSize or '14px' }}; text-align: right;">{{ (variant.profile.title or profile.title) | safe }}</span>
</div>
<p class="mb-0" style="font-size: 16px;">{{ variant.profile.description or profile.description }}</p>
</div>
<div class="pb-0">
  {% set items = experience | forVariant(variant.key) | sortByDateDesc %}
  {% set sectionTitle = "Experience" %}
  {% set sectionIcon = "mdi:office-building" %}
  {% include "partials/cv-item.njk" %}
</div>
<div class="pb-0">
  {% set items = education | sortByDateDesc %}
  {% set sectionTitle = "Education" %}
  {% set sectionIcon = "mdi:school" %}
  {% set hideDates = true %}
  {% include "partials/cv-item.njk" %}
</div>
</div>
<div class="d-flex flex-row align-items-stretch p-0 m-0" style="height: 11in; width: 1.8in; border-left: 1px solid #ddd;">
<div class="d-flex flex-column justify-content-between mb-5 mt-5 pt-3 pb-3 pe-2" style="padding-left: 8px;">
  {% set items = sidebar | sidebarForVariant(variant) %}
  {% include "partials/sidebar.njk" %}
</div>
</div>
</div>
</div>
</div>