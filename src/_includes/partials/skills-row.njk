{%- for section in sections %}{% if section.heading == "skills" %}
<div>
  <h2 class="section-rule mt-0 mb-2 border-0 pb-0"><span class="d-inline-flex align-items-center"><iconify-icon icon="mdi:hammer-wrench" style="margin-right: 6px;"></iconify-icon>Skills</span></h2>
  <div class="text-muted text-center" style="font-size: 13px; line-height: 1.6;">{% for i in section.items %}<span class="text-nowrap">{{ i.name }}</span>{{ " • " if not loop.last }}{% endfor %}</div>
</div>
{%- endif %}{% endfor %}
