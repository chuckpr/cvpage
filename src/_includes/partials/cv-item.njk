<h2 class="section-title d-flex justify-content-between align-items-center pt-0 pb-0 mt-0 mb-1" style="font-size: 20px;">
  {{ sectionTitle }}
  <iconify-icon icon="{{ sectionIcon }}"></iconify-icon>
</h2>
<div class="timeline">
  {% for item in items %}
    <div class="timeline-item mb-1">
      <div class="timeline-dot"></div>
      <div class="mb-0">
        <div class="d-flex justify-content-between align-items-center mb-0">
          <h3 class="mt-0 mb-0" style="font-size: 16px;">{{ item.organization or item.institution }}</h3>
          {% if not hideDates %}
            <span class="text-end text-muted ms-2" style="font-family: monospace; letter-spacing: -0.02em; font-size: 13px; white-space: nowrap;">{{ item.period or (item.begin + "–" + item.end) }}</span>
          {% endif %}
        </div>
        <div class="d-flex justify-content-between align-items-baseline" style="margin-top: 4px;">
          <h4 class="mt-0 mb-0" style="font-size: 13px; font-weight: 600; padding-left: 12px;">{{ item.title or (item.degree + " " + item.field) }}</h4>
          {% if item.location and item.location.trim() %}
            <span class="float-end text-muted fst-italic" style="white-space: nowrap; font-size: 13px;">{{ item.location }}</span>
          {% endif %}
        </div>
      </div>
      {% set notes = item.notes | forVariant(variant.key) %}
      {% if notes and notes.length > 0 %}
        <div class="mt-0" style="font-size: 11px; font-weight: 400;">
          <ul class="mb-0" style="padding-left: 16px;">
            {% for note in notes %}
              <li>{{ note | noteText(variant.key) }}
                {% if note.children and note.children.length %}
                  <ul class="mb-0" style="padding-left: 16px; list-style: circle;">
                    {% for child in note.children %}
                      <li>{{ child | noteText(variant.key) }}</li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>